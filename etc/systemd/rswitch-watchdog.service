[Unit]
Description=rSwitch Watchdog
Documentation=https://github.com/rswitch
PartOf=rswitch.service
After=rswitch.service

[Service]
Type=notify
ExecStart=/opt/rswitch/build/rswitch-watchdog -i 10 -r
WatchdogSec=30
Restart=on-failure
RestartSec=5
Environment=RSWITCH_WATCHDOG_IFACES=ens34,ens35,ens36,ens37

[Install]
WantedBy=multi-user.target
